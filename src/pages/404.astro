---
// ============================================================================
// /404 — Página de error técnica (SEO Maestro 2026-07-10).
// ----------------------------------------------------------------------------
// SIN este archivo, Cloudflare Pages entra en modo SPA-fallback y responde la
// HOME con HTTP 200 para CUALQUIER ruta inexistente (soft-404 masivo: URLs
// basura indexables y hasta imágenes rotas devolviendo HTML 200 — visto en
// informate-mx.pages.dev). Con dist/404.html, Pages responde 404 real.
// noindex + excluida del sitemap (el filter ya descarta /404).
// ============================================================================
import PageLayout from '@layouts/PageLayout.astro'
import SectionMenu from '@components/SectionMenu.astro'

const cierreItems = [
  { label: 'Inicio', href: '/', sub: 'Volver a la portada' },
  { label: 'Todos los artículos', href: '/blog', sub: 'Explora la cobertura' },
  { label: 'Nosotros', href: '/nosotros', sub: 'Qué es Infórmate' },
  { label: 'Contacto', href: '/contacto', sub: 'Escríbenos' },
]
const cierreCta = { label: 'Ir al inicio', href: '/', sub: 'Portada del portal' }
---

<PageLayout
  title="Página no encontrada (404)"
  description="La página que buscas no existe o cambió de dirección. Vuelve a la portada de Infórmate.mx o explora los artículos del portal."
  pageType="page"
  noindex={true}
  guia={false}
>
  <section class="section">
    <div class="container nf">
      <p class="nf__code">404</p>
      <h1 class="nf__title">Página no encontrada</h1>
      <p class="nf__desc">
        La dirección que abriste no existe o cambió. Puedes volver a la portada
        o explorar los artículos del portal.
      </p>
      <p class="nf__actions">
        <a class="btn btn--primary" href="/">Ir a la portada</a>
        <a class="btn" href="/blog">Ver artículos</a>
      </p>
    </div>
  </section>

  <SectionMenu items={cierreItems} cta={cierreCta} ariaLabel="Rutas para continuar" />
</PageLayout>

<style>
  .container { max-width: var(--container-max); margin-inline: auto; padding-inline: var(--container-px); }
  .section { padding: var(--sp-10) 0; }
  .nf { text-align: center; }
  .nf__code { font-family: var(--font-heading); font-weight: 800; font-size: clamp(4rem, 12vw, 8rem); line-height: 1; color: var(--c-primary); margin: 0; }
  .nf__title { font-family: var(--font-heading); margin: var(--sp-3) 0; }
  .nf__desc { color: var(--c-muted); max-width: 46ch; margin: 0 auto var(--sp-5); }
  .nf__actions { display: flex; gap: var(--sp-3); justify-content: center; flex-wrap: wrap; }
</style>
